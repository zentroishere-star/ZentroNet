# Django Settings
# For production, generate a new SECRET_KEY using: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here

# Debug mode (set to True for local development, False for production)
DEBUG=True

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Database URL (leave as is for SQLite development, update for production)
# SQLite (development): sqlite:///db.sqlite3
# PostgreSQL (production): postgresql://user:password@localhost:5432/dbname
DATABASE_URL=sqlite:///db.sqlite3

# Railway/Render deployment (optional)
RAILWAY_PUBLIC_DOMAIN=

# Security settings (automatically handled based on DEBUG setting)
# Override these only if needed for special cases
# SESSION_COOKIE_SECURE=False
# CSRF_COOKIE_SECURE=False
# SECURE_SSL_REDIRECT=False

# Optional: Email configuration (for password resets)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
